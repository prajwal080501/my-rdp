PORT=4000
MONGO_URI=mongodb://localhost:27017/beam
# Must match the signaling server's JWT_SECRET exactly — it verifies the
# device tokens this service issues.
JWT_SECRET=change-me-to-a-long-random-string

# S3-compatible object storage for session recordings. Leave S3_ENDPOINT unset
# for real AWS S3; set it (e.g. http://localhost:9000) to point at MinIO.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=beam-recordings
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
